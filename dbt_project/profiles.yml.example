# Copy to profiles.yml and fill in your GCP project ID.
# profiles.yml is gitignored -- never commit it.

stratum:
  target: dev
  outputs:
    dev:
      type: bigquery
      method: service-account
      project: YOUR_GCP_PROJECT_ID
      dataset: dbt_dev
      keyfile: ../credentials.json
      location: US
      threads: 4
      timeout_seconds: 300
    prod:
      type: bigquery
      method: service-account
      project: YOUR_GCP_PROJECT_ID
      dataset: dbt_prod
      keyfile: ../credentials.json
      location: US
      threads: 8
      timeout_seconds: 300
